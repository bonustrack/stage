# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat id. To find it: send any message to your bot, then GET
# https://api.telegram.org/bot<TOKEN>/getUpdates and read result[0].message.chat.id
TELEGRAM_CHAT_ID=

# OpenAI API key — required only if you want to reply to Ask with a Telegram
# voice note. The MCP transcribes the audio and delivers text to the agent.
# (Claude doesn't accept raw audio input yet, so transcription is the only
# way to relay voice replies.)
OPENAI_API_KEY=

# Optional: transcription model. Defaults to gpt-4o-mini-transcribe.
# Other valid choices: gpt-4o-transcribe, whisper-1
OPENAI_TRANSCRIBE_MODEL=

# --- Remote-MCP options ---
# Set PORT (or MCP_HTTP_PORT) to expose the server over Streamable HTTP at
# /mcp instead of stdio. Required for remote use (claude.ai, chatgpt.com, etc.).
# Leave unset for local Claude Desktop / Cursor / Claude Code spawning.
PORT=

# Bearer token to protect the public HTTP endpoint. Strongly recommended when
# PORT is set — without it, anyone who finds the URL can use your Telegram
# bot and OpenAI key.
MCP_AUTH_TOKEN=

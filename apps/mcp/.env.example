# Telegram bot token from @BotFather. Required in all modes.
TELEGRAM_BOT_TOKEN=

# Single-tenant chat id, used by stdio mode only (local Claude Desktop /
# Cursor / Claude Code spawning). Find it: send any message to your bot then
# GET https://api.telegram.org/bot<TOKEN>/getUpdates and read result[0].message.chat.id
# Not used in HTTP mode — there each user binds their own chat via OAuth.
TELEGRAM_CHAT_ID=

# OpenAI API key — required only if you want to reply to Ask with a Telegram
# voice note. The MCP transcribes the audio and delivers text to the agent.
OPENAI_API_KEY=

# Optional: transcription model. Defaults to gpt-4o-mini-transcribe.
# Other valid choices: gpt-4o-transcribe, whisper-1
OPENAI_TRANSCRIBE_MODEL=

# --- HTTP / multi-tenant options ---
# Set PORT (or MCP_HTTP_PORT) to expose the server over Streamable HTTP at
# /mcp. Required for remote use (claude.ai, chatgpt.com, etc.). HTTP mode is
# multi-tenant and requires OAuth 2.1: each user authorizes by tapping a
# Telegram bot deep link generated during the /authorize flow.
PORT=

# Public base URL of the MCP server. Used as the OAuth `issuer` and embedded
# in metadata documents — must match what clients reach. If unset, derived
# per-request from x-forwarded-proto / x-forwarded-host / Host. Set this
# explicitly when running behind a proxy that doesn't forward those headers.
METRO_BASE_URL=

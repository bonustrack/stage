# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: restrict the bot to a single chat id. If unset, the bot replies to
# anyone who messages it (don't ship like that on Fly.io / sprites.dev).
TELEGRAM_CHAT_ID=

# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Optional: model. Defaults to claude-opus-4-7 (1M context).
ANTHROPIC_MODEL=

# Optional: system prompt. Defaults to a short Telegram-friendly assistant.
SYSTEM_PROMPT=

# Optional: OpenAI API key — only needed if you want to send VOICE notes to
# the bot. Voice replies get transcribed via gpt-4o-mini-transcribe.
OPENAI_API_KEY=

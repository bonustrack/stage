{
  "extends": ["expo/tsconfig.base", "@stage-labs/config/tsconfig/react-native.json"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "react-native": ["./node_modules/react-native"],
      "react-native-svg": ["./node_modules/react-native-svg"],
      "react-native-markdown-display": ["./node_modules/react-native-markdown-display"]
    }
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "components/**/*.ts", "components/**/*.tsx", "lib/**/*.ts"]
}

<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- Permissions are also declared by the config plugin (withMetroPill) so they
       land in the merged manifest even if module-manifest merge order changes.
       Declaring them here keeps the module self-describing. -->
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
  <uses-permission android:name="android.permission.RECORD_AUDIO" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

  <application>
    <service
      android:name="box.metro.pill.OverlayService"
      android:exported="false"
      android:foregroundServiceType="microphone" />

    <!-- Custom FCM service: renders avatar data-pushes with a round largeIcon,
         delegates everything else to Expo's service. Higher intent-filter
         priority so it wins over ExpoFirebaseMessagingService as the default
         MESSAGING_EVENT receiver. -->
    <service
      android:name="box.metro.pill.MetroFcmService"
      android:exported="false">
      <intent-filter android:priority="1">
        <action android:name="com.google.firebase.MESSAGING_EVENT" />
      </intent-filter>
    </service>
  </application>
</manifest>

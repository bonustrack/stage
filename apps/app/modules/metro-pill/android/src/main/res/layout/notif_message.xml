<?xml version="1.0" encoding="utf-8"?>
<!-- Collapsed custom notification: round avatar on the LEFT (Telegram-style),
     title + single-line body to its right. Fed to setCustomContentView().
     Text colours use the system notification text appearances so they adapt to
     light/dark notification shades. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <ImageView
        android:id="@+id/metro_notif_avatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/metro_notif_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:ellipsize="end"
            android:textAppearance="@android:style/TextAppearance.Material.Notification.Title" />

        <TextView
            android:id="@+id/metro_notif_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:ellipsize="end"
            android:textAppearance="@android:style/TextAppearance.Material.Notification" />
    </LinearLayout>
</LinearLayout>

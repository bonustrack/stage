{
  "extends": ["./tsconfig.json", "@stage-labs/config/tsconfig/eslint.json"],
  "compilerOptions": {
    "types": ["react", "react-native", "bun"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "modules/**/*.ts",
    "modules/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx"
  ]
}

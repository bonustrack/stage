{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "18.20.4",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug -PreactNativeArchitectures=arm64-v8a"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "18.20.4",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "18.20.4",
      "env": { "APP_VARIANT": "prod" }
    },
    "development-prod": {
      "extends": "development",
      "env": { "APP_VARIANT": "prod" }
    },
    "preview-prod": {
      "extends": "preview",
      "env": { "APP_VARIANT": "prod" }
    },
    "production-prod": {
      "extends": "production",
      "env": { "APP_VARIANT": "prod" }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal",
        "applicationId": "box.stage"
      }
    }
  }
}

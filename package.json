{
  "name": "metro-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for Metro — live JSON stream of Telegram + Discord messages for local Claude Code / Codex sessions.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bonustrack/metro.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=22"
  },
  "patchedDependencies": {
    "react-native-screens@4.16.0": "patches/react-native-screens@4.16.0.patch",
    "nodejs-mobile-react-native@18.20.4": "patches/nodejs-mobile-react-native@18.20.4.patch"
  }
}

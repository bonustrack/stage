{
  "name": "@stage-labs/metro",
  "version": "0.1.0-beta.4",
  "description": "Dispatcher daemon that bridges Codex / Claude Code agent sessions with Telegram, Discord, and GitHub mentions. Each chat thread / topic / issue gets its own agent session, with streaming responses and tool-call visibility.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bonustrack/metro.git"
  },
  "homepage": "https://github.com/bonustrack/metro#readme",
  "bugs": "https://github.com/bonustrack/metro/issues",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "metro": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.14.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.1.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.3.0",
    "typescript": "^5",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "bun@1.3.9"
}

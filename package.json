{
  "name": "stage-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for Stage — live JSON stream of Telegram + Discord messages for local Claude Code / Codex sessions.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bonustrack/stage.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "madge": "stage-madge apps/app/app apps/app/components apps/app/lib apps/app/modules packages/client/src packages/kit/src",
    "knip": "knip",
    "check": "bun run lint && turbo run typecheck",
    "report:deps": "bun run madge || true; bun run knip || true",
    "served:reset": "bash scripts/served-reset.sh",
    "served:drift-check": "bash scripts/served-drift-check.sh",
    "worktree:prune": "bash scripts/worktree-prune.sh"
  },
  "devDependencies": {
    "@stage-labs/config": "workspace:*",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.0.0",
    "knip": "^6.15.0",
    "madge": "^8.0.0",
    "turbo": "^2.3.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.2",
    "vue-eslint-parser": "^10.0.0"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=22"
  },
  "patchedDependencies": {
    "nodejs-mobile-react-native@18.20.4": "patches/nodejs-mobile-react-native@18.20.4.patch"
  }
}

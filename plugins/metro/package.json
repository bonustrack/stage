{
  "name": "@metro-labs/mcp",
  "version": "0.7.1",
  "description": "Claude Code and Codex plugin: Telegram + Discord channel that surfaces inbound messages live in-session and lets the agent reply, react, and edit-message.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "start": "bun install --no-summary && bun src/server.ts",
    "start:codex-bridge": "bun install --no-summary && bun src/codex-bridge.ts",
    "start:codex-mcp": "bun install --no-summary && bun src/codex-mcp.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "discord.js": "^14.14.0",
    "pino": "^9.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9"
}

{
  "name": "@metro-labs/mcp",
  "version": "0.5.2",
  "description": "Claude Code plugin: Telegram + Discord channel that surfaces inbound messages live in-session and lets the agent reply, react, and edit-message.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "start": "bun install --no-summary && bun src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "discord.js": "^14.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9"
}

{
  "name": "@metro-labs/kit",
  "version": "0.1.0",
  "private": true,
  "description": "Shared design-system primitives for the Metro clients (web + mobile): colour/spacing tokens, HeroIcon path data, station icon definitions, theme-preference contract. Framework-agnostic data - the renderers stay per-framework.",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens": "./src/tokens.ts",
    "./icons": "./src/icons.ts",
    "./theme": "./src/theme.ts",
    "./avatar": "./src/avatar.ts",
    "./layout": "./src/layout.ts",
    "./button": "./src/button.tsx",
    "./text": "./src/text.tsx",
    "./title": "./src/title.tsx",
    "./icon": "./src/icon.tsx",
    "./card": "./src/card.tsx",
    "./list-view": "./src/list-view.tsx",
    "./divider": "./src/divider.tsx",
    "./caption": "./src/caption.tsx",
    "./image": "./src/image.tsx",
    "./spacer": "./src/spacer.tsx",
    "./label": "./src/label.tsx",
    "./input": "./src/input.tsx",
    "./textarea": "./src/textarea.tsx",
    "./checkbox": "./src/checkbox.tsx",
    "./radio-group": "./src/radio-group.tsx",
    "./select": "./src/select.tsx",
    "./date-picker": "./src/date-picker.tsx",
    "./form": "./src/form.tsx",
    "./box": "./src/box.tsx",
    "./avatar-view": "./src/avatar.tsx",
    "./markdown": "./src/markdown.tsx",
    "./table": "./src/table.tsx",
    "./scroll": "./src/scroll.tsx",
    "./pressable": "./src/pressable.tsx",
    "./flat-list": "./src/flat-list.tsx"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-svg": "*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^10.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.2"
  }
}

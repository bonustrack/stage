{
  "type": "Col",
  "gap": 12,
  "children": [
    {
      "$repeat": "questions",
      "$item": {
        "type": "Col",
        "gap": 6,
        "children": [
          {
            "$if": "item.hasQuestion",
            "type": "Text", "value": "{{item.question}}", "weight": "semibold", "size": "3xl"
          },
          {
            "$if": "item.hasHeader",
            "type": "Caption",
            "value": "{{item.headerLabel}}",
            "color": "secondary",
            "weight": "semibold"
          },
          {
            "$repeat": "item.options",
            "$item": [
              {
                "$if": "item.bare",
                "type": "Stack",
                "children": [
                  {
                    "type": "Box",
                    "inset": 0,
                    "radius": "lg",
                    "background": "{{item.background}}",
                    "border": { "size": 1, "color": "{{item.borderColor}}" }
                  },
                  {
                    "type": "Box",
                    "position": "absolute",
                    "left": 0,
                    "top": 0,
                    "bottom": 0,
                    "width": "{{item.fillWidth}}",
                    "radius": "lg",
                    "background": "{{item.fillBackground}}"
                  },
                  {
                    "type": "Row",
                    "align": "center",
                    "justify": "between",
                    "gap": 8,
                    "padding": { "x": 12, "y": 8 },
                    "children": [
                      {
                        "type": "Col",
                        "flex": 1,
                        "children": [{ "type": "Text", "value": "{{item.label}}", "truncate": true }]
                      },
                      { "type": "Caption", "value": "{{item.stats}}", "color": "secondary", "weight": "semibold" }
                    ]
                  }
                ]
              },
              {
                "$if": "item.pressable",
                "type": "Pressable",
                "onClickAction": {
                  "type": "{{pollPressType}}",
                  "payload": { "questionIndex": "{{item.qi}}", "optionIndex": "{{item.oi}}", "selected": "{{item.selected}}" }
                },
                "children": [
                  {
                    "type": "Stack",
                    "children": [
                      {
                        "type": "Box",
                        "inset": 0,
                        "radius": "lg",
                        "background": "{{item.background}}",
                        "border": { "size": 1, "color": "{{item.borderColor}}" }
                      },
                      {
                        "type": "Box",
                        "position": "absolute",
                        "left": 0,
                        "top": 0,
                        "bottom": 0,
                        "width": "{{item.fillWidth}}",
                        "radius": "lg",
                        "background": "{{item.fillBackground}}"
                      },
                      {
                        "type": "Row",
                        "align": "center",
                        "justify": "between",
                        "gap": 8,
                        "padding": { "x": 12, "y": 8 },
                        "children": [
                          {
                            "type": "Col",
                            "flex": 1,
                            "children": [{ "type": "Text", "value": "{{item.label}}", "truncate": true }]
                          },
                          { "type": "Caption", "value": "{{item.stats}}", "color": "secondary", "weight": "semibold" }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          { "type": "Caption", "value": "{{item.totalLabel}}", "color": "secondary" }
        ]
      }
    }
  ]
}

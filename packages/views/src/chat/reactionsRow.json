{
  "type": "Row",
  "gap": 4,
  "wrap": "wrap",
  "align": "center",
  "children": [
    {
      "$repeat": "reactions",
      "$item": [
        {
          "$if": "item.bare",
          "type": "Row",
          "align": "center",
          "gap": 4,
          "padding": { "x": 8, "y": 2 },
          "radius": "full",
          "background": "{{item.background}}",
          "border": "{{item.border}}",
          "children": [
            { "type": "Text", "value": "{{item.emoji}}", "size": "xs" },
            { "type": "Caption", "value": "{{item.count}}", "color": "secondary" }
          ]
        },
        {
          "$if": "item.pressable",
          "type": "ListViewItem",
          "onClickAction": {
            "type": "{{reactionPressType}}",
            "payload": { "messageId": "{{messageId}}", "emoji": "{{item.emoji}}" }
          },
          "children": [
            {
              "type": "Row",
              "align": "center",
              "gap": 4,
              "padding": { "x": 8, "y": 2 },
              "radius": "full",
              "background": "{{item.background}}",
              "border": "{{item.border}}",
              "children": [
                { "type": "Text", "value": "{{item.emoji}}", "size": "xs" },
                { "type": "Caption", "value": "{{item.count}}", "color": "secondary" }
              ]
            }
          ]
        }
      ]
    }
  ]
}

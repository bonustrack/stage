{
  "type": "Row",
  "radius": "2xl",
  "background": "{{background}}",
  "maxWidth": 280,
  "minWidth": 200,
  "padding": { "x": 9, "y": 7 },
  "align": "center",
  "children": [
    {
      "type": "AudioPlayer",
      "src": "{{src}}",
      "duration": "{{duration}}",
      "waveform": true,
      "bars": "{{bars}}",
      "barCount": "{{barCount}}",
      "accent": "{{background}}",
      "onAccent": "{{onAccent}}",
      "onPlayAction": { "type": "{{playType}}", "payload": { "src": "{{src}}" } }
    }
  ]
}

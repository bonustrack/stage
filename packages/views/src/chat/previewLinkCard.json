{
  "type": "ListViewItem",
  "onClickAction": { "type": "{{linkAction}}", "payload": { "url": "{{url}}" } },
  "children": [
    {
      "type": "Col",
      "radius": "lg",
      "gap": 0,
      "children": [
        {
          "$if": "hasImage",
          "type": "Image",
          "src": "{{imageUri}}",
          "radius": "md",
          "maxHeight": 160,
          "fit": "cover"
        },
        {
          "type": "Col",
          "gap": 2,
          "padding": { "x": 12, "y": 10 },
          "children": [
            { "type": "Text", "value": "{{title}}", "weight": "semibold", "truncate": true },
            {
              "$if": "hasSubtitle",
              "type": "Caption",
              "value": "{{subtitle}}",
              "color": "secondary",
              "maxLines": 2
            }
          ]
        }
      ]
    }
  ]
}

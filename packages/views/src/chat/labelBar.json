{
  "type": "ScrollRow",
  "gap": 8,
  "padding": { "x": 16, "top": 14, "bottom": 7 },
  "children": [
    {
      "$repeat": "chips",
      "$item": {
        "type": "Pressable",
        "onClickAction": { "type": "{{pressType}}", "payload": { "value": "{{item.value}}" } },
        "children": [
          {
            "type": "Row",
            "height": 26,
            "radius": "full",
            "padding": { "x": 9, "y": 2 },
            "align": "center",
            "background": "{{item.background}}",
            "children": [
              { "type": "Text", "value": "{{item.label}}", "size": "md", "color": "{{item.labelColor}}", "truncate": true }
            ]
          }
        ]
      }
    }
  ]
}

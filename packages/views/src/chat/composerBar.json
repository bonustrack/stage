{
  "type": "Row",
  "align": "center",
  "gap": 8,
  "children": [
    {
      "$if": "hasAttach",
      "type": "Button",
      "iconStart": "{{attachIcon}}",
      "variant": "ghost",
      "size": "sm",
      "onClickAction": { "type": "{{attachAction}}", "payload": {} }
    },
    {
      "type": "TextField",
      "name": "{{fieldName}}",
      "value": "{{value}}",
      "placeholder": "{{placeholder}}",
      "multiline": true,
      "autoGrow": true,
      "onChangeAction": { "type": "{{changeAction}}", "payload": {} }
    },
    {
      "$if": "hasSend",
      "type": "Button",
      "iconStart": "{{sendIcon}}",
      "variant": "solid",
      "size": "sm",
      "disabled": "{{sendDisabled}}",
      "onClickAction": { "type": "{{sendAction}}", "payload": {} }
    }
  ]
}

{
  "type": "TextField",
  "name": "composer",
  "value": "{{value}}",
  "variant": "plain",
  "multiline": true,
  "autoGrow": true,
  "fontSize": "{{fontSize}}",
  "fontWeight": "medium",
  "color": "{{color}}",
  "paddingX": 8,
  "paddingTop": 4,
  "paddingBottom": 8,
  "lineHeight": 23,
  "minHeight": 24,
  "maxHeight": 210,
  "autoCapitalize": "sentences",
  "placeholder": "Message",
  "placeholderColor": "{{placeholderColor}}",
  "focusNonce": "{{focusNonce}}",
  "blurNonce": "{{blurNonce}}",
  "selection": { "start": "{{selStart}}", "end": "{{selEnd}}" },
  "onChangeAction": { "type": "{{changeType}}" },
  "onSelectionChangeAction": { "type": "{{selectionType}}" }
}

{
  "type": "Row",
  "align": "center",
  "gap": 8,
  "children": [
    {
      "$if": "pressable",
      "type": "ListViewItem",
      "onClickAction": {
        "type": "{{conversationPressType}}",
        "payload": { "conversationId": "{{conversationId}}" }
      },
      "align": "center",
      "children": [
        {
          "type": "Row",
          "align": "center",
          "gap": 10,
          "flex": 1,
          "children": [
            {
              "$if": "hasAvatar",
              "type": "Image",
              "src": "{{avatarUri}}",
              "size": 32,
              "radius": "full"
            },
            {
              "type": "Col",
              "gap": 2,
              "flex": 1,
              "children": [
                { "type": "Text", "value": "{{title}}", "weight": "semibold", "truncate": true },
                {
                  "$if": "hasSubtitle",
                  "type": "Caption",
                  "value": "{{subtitle}}",
                  "color": "secondary",
                  "truncate": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "$if": "static",
      "type": "Row",
      "align": "center",
      "gap": 10,
      "flex": 1,
      "children": [
        {
          "$if": "hasAvatar",
          "type": "Image",
          "src": "{{avatarUri}}",
          "size": 32,
          "radius": "full"
        },
        {
          "type": "Col",
          "gap": 2,
          "flex": 1,
          "children": [
            { "type": "Text", "value": "{{title}}", "weight": "semibold", "truncate": true },
            {
              "$if": "hasSubtitle",
              "type": "Caption",
              "value": "{{subtitle}}",
              "color": "secondary",
              "truncate": true
            }
          ]
        }
      ]
    },
    {
      "$repeat": "trailing",
      "$item": {
        "type": "Button",
        "iconStart": "{{item.icon}}",
        "variant": "ghost",
        "size": "sm",
        "onClickAction": "{{item.action}}"
      }
    }
  ]
}

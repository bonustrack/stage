{
  "type": "ListViewItem",
  "onClickAction": {
    "type": "{{pressAction}}",
    "payload": {
      "convId": "{{convId}}",
      "longPressType": "{{longPressType}}",
      "labelPressType": "{{labelPressType}}"
    }
  },
  "align": "center",
  "gap": 12,
  "children": [
    {
      "type": "Row",
      "align": "center",
      "gap": 12,
      "flex": 1,
      "children": [
        {
          "$if": "showAvatar",
          "type": "Image",
          "src": "{{avatarUri}}",
          "size": 44,
          "radius": "full"
        },
        {
          "type": "Col",
          "gap": 2,
          "flex": 1,
          "children": [
            {
              "type": "Row",
              "align": "center",
              "gap": 4,
              "flex": 1,
              "children": [
                {
                  "$if": "pinned",
                  "type": "Icon",
                  "name": "map-pin",
                  "size": "xs",
                  "color": "secondary"
                },
                {
                  "$repeat": "titles",
                  "$item": {
                    "type": "Text",
                    "value": "{{item.text}}",
                    "weight": "{{item.weight}}",
                    "color": "{{item.color}}",
                    "background": "{{item.background}}",
                    "truncate": true
                  }
                }
              ]
            },
            {
              "type": "Row",
              "align": "center",
              "gap": 4,
              "children": [
                {
                  "$if": "hasPreviewPrefix",
                  "type": "Caption",
                  "value": "{{previewPrefix}}",
                  "color": "info",
                  "weight": "semibold"
                },
                { "type": "Caption", "value": "{{preview}}", "color": "secondary", "truncate": true, "maxLines": 1 }
              ]
            },
            {
              "$if": "hasChips",
              "type": "Row",
              "gap": 4,
              "wrap": "wrap",
              "children": [
                {
                  "$repeat": "chips",
                  "$item": [
                    {
                      "$if": "item.bare",
                      "type": "Badge",
                      "label": "{{item.label}}",
                      "color": "{{item.color}}",
                      "variant": "soft",
                      "size": "sm"
                    },
                    {
                      "$if": "item.pressable",
                      "type": "ListViewItem",
                      "onClickAction": {
                        "type": "{{labelPressType}}",
                        "payload": { "convId": "{{convId}}", "label": "{{item.label}}" }
                      },
                      "children": [
                        {
                          "type": "Badge",
                          "label": "{{item.label}}",
                          "color": "{{item.color}}",
                          "variant": "soft",
                          "size": "sm"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "Col",
          "gap": 4,
          "align": "end",
          "children": [
            { "type": "Caption", "value": "{{timestamp}}", "color": "secondary" },
            {
              "$if": "hasUnreadBadge",
              "type": "Badge",
              "label": "{{unreadBadge}}",
              "color": "info",
              "size": "sm",
              "pill": true
            },
            {
              "$if": "showUnreadDot",
              "type": "Badge",
              "label": " ",
              "color": "info",
              "size": "sm",
              "pill": true
            }
          ]
        }
      ]
    }
  ]
}

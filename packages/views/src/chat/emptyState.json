{
  "type": "Col",
  "align": "center",
  "justify": "center",
  "gap": 8,
  "padding": 24,
  "children": [
    {
      "$if": "hasIcon",
      "type": "Icon",
      "name": "{{icon}}",
      "size": "3xl",
      "color": "secondary"
    },
    { "type": "Text", "value": "{{title}}", "weight": "semibold", "textAlign": "center" },
    {
      "$if": "hasCaption",
      "type": "Caption",
      "value": "{{caption}}",
      "color": "secondary",
      "textAlign": "center"
    },
    {
      "$if": "hasAction",
      "type": "Button",
      "label": "{{actionLabel}}",
      "variant": "soft",
      "size": "sm",
      "onClickAction": { "type": "{{emptyPressType}}", "payload": { "id": "{{actionId}}" } }
    }
  ]
}

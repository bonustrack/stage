{
  "type": "Col",
  "gap": 6,
  "align": "{{align}}",
  "children": [
    {
      "$if": "avatarUri",
      "type": "Image",
      "src": "{{avatarUri}}",
      "size": 88,
      "radius": "full"
    },
    { "type": "Text", "value": "{{name}}", "weight": "semibold", "size": "4xl", "textAlign": "{{textAlign}}" },
    {
      "$if": "hasHandle",
      "type": "Text",
      "value": "{{handle}}",
      "size": "md",
      "color": "secondary",
      "textAlign": "{{textAlign}}"
    },
    {
      "$if": "hasBio",
      "type": "Text",
      "value": "{{bio}}",
      "size": "sm",
      "color": "secondary",
      "textAlign": "{{textAlign}}"
    },
    {
      "$if": "hasStats",
      "type": "Row",
      "gap": 20,
      "align": "center",
      "padding": { "top": 4 },
      "children": [
        {
          "$repeat": "stats",
          "$item": {
            "type": "Col",
            "gap": 0,
            "align": "start",
            "children": [
              { "type": "Text", "value": "{{item.value}}", "weight": "semibold", "size": "lg" },
              { "type": "Caption", "value": "{{item.label}}", "color": "secondary" }
            ]
          }
        }
      ]
    },
    {
      "$if": "hasActions",
      "type": "Row",
      "gap": 12,
      "align": "center",
      "padding": { "top": 8 },
      "children": [
        {
          "$repeat": "actions",
          "$item": {
            "type": "Button",
            "label": "{{item.label}}",
            "iconStart": "{{item.icon}}",
            "variant": "soft",
            "color": "primary",
            "onClickAction": { "type": "{{actionPressType}}", "payload": "{{item.payload}}" }
          }
        }
      ]
    }
  ]
}

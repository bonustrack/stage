{
  "type": "ListViewItem",
  "onClickAction": "{{clickAction}}",
  "align": "center",
  "gap": 12,
  "children": [
    {
      "$if": "iconStart",
      "type": "Icon",
      "name": "{{iconStart}}",
      "color": "link",
      "size": "xl"
    },
    {
      "type": "Col",
      "flex": 1,
      "children": [{ "type": "Text", "value": "{{label}}", "size": "xl", "color": "link", "truncate": true }]
    },
    {
      "$if": "hasValue",
      "type": "Text",
      "value": "{{value}}",
      "color": "secondary",
      "truncate": true
    },
    { "type": "Icon", "name": "{{iconEnd}}", "color": "secondary", "size": "lg" }
  ]
}

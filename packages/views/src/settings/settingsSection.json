{
  "type": "Col",
  "gap": "{{gap}}",
  "children": [
    {
      "$if": "hasTitle",
      "type": "Caption",
      "value": "{{titleUpper}}",
      "color": "secondary",
      "size": "sm"
    },
    {
      "$if": "hasCaption",
      "type": "Caption",
      "value": "{{caption}}",
      "color": "secondary"
    },
    { "$repeat": "children", "$item": "{{item}}" }
  ]
}

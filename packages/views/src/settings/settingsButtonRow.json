{
  "type": "ListViewItem",
  "align": "{{align}}",
  "gap": 12,
  "onClickAction": { "type": "{{clickType}}", "payload": "{{payload}}" },
  "children": [
    {
      "$if": "iconStart",
      "type": "Icon",
      "name": "{{iconStart}}",
      "color": "{{tone}}",
      "size": "xl"
    },
    {
      "type": "Col",
      "gap": 2,
      "flex": 1,
      "children": [
        { "type": "Text", "value": "{{label}}", "size": "md", "weight": "semibold", "color": "{{tone}}" },
        {
          "$if": "hasDescription",
          "type": "Caption",
          "value": "{{description}}",
          "color": "secondary"
        }
      ]
    }
  ]
}

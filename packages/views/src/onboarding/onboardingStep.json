{
  "type": "Col",
  "flex": 1,
  "justify": "between",
  "children": [
    {
      "type": "Col",
      "gap": 10,
      "padding": { "top": "{{topPadding}}" },
      "children": [
        {
          "$if": "imageUri",
          "type": "Image",
          "src": "{{imageUri}}",
          "size": 96,
          "radius": "lg"
        },
        { "type": "Title", "value": "{{title}}" },
        {
          "$if": "caption",
          "type": "Text",
          "value": "{{caption}}",
          "size": "{{captionSize}}",
          "color": "secondary"
        }
      ]
    },
    {
      "$if": "hasActions",
      "type": "Col",
      "gap": 10,
      "children": [
        {
          "$repeat": "actions",
          "$item": {
            "type": "Button",
            "label": "{{item.label}}",
            "block": true,
            "size": "lg",
            "variant": "{{item.variant}}",
            "disabled": "{{item.disabled}}",
            "onClickAction": { "type": "{{actionPressType}}", "payload": { "id": "{{item.id}}" } }
          }
        }
      ]
    }
  ]
}

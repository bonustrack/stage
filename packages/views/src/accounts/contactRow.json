{
  "type": "ListViewItem",
  "onClickAction": { "type": "{{contactPressType}}", "payload": "{{payload}}" },
  "align": "center",
  "gap": 12,
  "children": [
    {
      "type": "Row",
      "align": "center",
      "gap": 12,
      "flex": 1,
      "children": [
        { "type": "Image", "src": "{{avatarUri}}", "size": 40, "radius": "full" },
        {
          "type": "Col",
          "gap": 2,
          "flex": 1,
          "children": [
            { "type": "Text", "value": "{{name}}", "weight": "semibold", "truncate": true },
            {
              "$if": "hasHandle",
              "type": "Caption",
              "value": "{{handle}}",
              "color": "secondary",
              "truncate": true
            }
          ]
        },
        {
          "$if": "trailingBadge",
          "type": "Badge",
          "label": "{{trailingBadge}}",
          "color": "secondary",
          "variant": "soft",
          "size": "sm",
          "pill": true
        }
      ]
    }
  ]
}

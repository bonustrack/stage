{
  "type": "ListViewItem",
  "onClickAction": { "type": "{{memberPressType}}", "payload": { "memberId": "{{memberId}}" } },
  "align": "center",
  "gap": 12,
  "padding": { "x": 14, "y": 14 },
  "pressedBackground": "{{borderColor}}",
  "border": { "bottom": { "size": 1, "color": "{{borderColor}}" } },
  "children": [
    {
      "type": "Row",
      "align": "center",
      "gap": 12,
      "flex": 1,
      "children": [
        { "type": "Image", "src": "{{avatarUri}}", "size": 40, "radius": "full", "background": "{{borderColor}}" },
        {
          "type": "Col",
          "gap": 2,
          "flex": 1,
          "children": [
            { "type": "Text", "value": "{{name}}", "weight": "semibold", "truncate": true },
            {
              "$if": "hasAddress",
              "type": "Caption",
              "value": "{{address}}",
              "color": "secondary",
              "truncate": true
            }
          ]
        },
        {
          "$if": "badge",
          "type": "Badge",
          "label": "{{badge.label}}",
          "background": "{{badge.background}}",
          "color": "{{badge.color}}",
          "variant": "soft",
          "size": "3xs",
          "weight": "medium",
          "pill": true
        },
        {
          "$if": "removable",
          "type": "Button",
          "iconStart": "trash",
          "variant": "ghost",
          "uniform": true,
          "size": "xs",
          "radius": "full",
          "foreground": "{{dangerColor}}",
          "pressedBackground": "{{removePressedBg}}",
          "onClickAction": { "type": "{{memberRemoveType}}", "payload": { "memberId": "{{memberId}}" } }
        }
      ]
    }
  ]
}

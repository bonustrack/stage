{
  "type": "ListViewItem",
  "onClickAction": { "type": "{{accountPressType}}", "payload": { "accountId": "{{accountId}}" } },
  "align": "center",
  "gap": 12,
  "children": [
    {
      "type": "Row",
      "align": "center",
      "gap": 12,
      "flex": 1,
      "children": [
        { "type": "Image", "src": "{{avatarUri}}", "size": 40, "radius": "full" },
        {
          "type": "Col",
          "gap": 2,
          "flex": 1,
          "children": [
            { "type": "Text", "value": "{{name}}", "weight": "semibold", "truncate": true },
            { "type": "Caption", "value": "{{address}}", "color": "secondary", "truncate": true }
          ]
        },
        {
          "$if": "typeLabel",
          "type": "Badge",
          "label": "{{typeLabel}}",
          "color": "secondary",
          "variant": "soft",
          "size": "sm"
        }
      ]
    }
  ]
}

{
  "type": "ListViewItem",
  "onClickAction": { "type": "{{toggleType}}", "payload": { "address": "{{address}}" } },
  "align": "center",
  "gap": 10,
  "children": [
    {
      "type": "Row",
      "align": "center",
      "gap": 10,
      "flex": 1,
      "children": [
        { "type": "Image", "src": "{{avatarUri}}", "size": 36, "radius": "full" },
        {
          "type": "Col",
          "gap": 1,
          "flex": 1,
          "children": [
            { "type": "Text", "value": "{{name}}", "weight": "semibold", "truncate": true },
            {
              "$if": "hasHandle",
              "type": "Caption",
              "value": "{{handle}}",
              "color": "secondary",
              "truncate": true
            }
          ]
        },
        {
          "$if": "selected",
          "type": "Row",
          "width": 24,
          "height": 24,
          "radius": "lg",
          "background": "{{checkBackground}}",
          "align": "center",
          "justify": "center",
          "children": [{ "type": "Icon", "name": "check", "size": 14, "color": "#fff" }]
        },
        {
          "$if": "unselected",
          "type": "Row",
          "width": 24,
          "height": 24,
          "radius": "lg",
          "align": "center",
          "justify": "center",
          "border": { "size": 2, "color": "{{checkBackground}}" },
          "children": []
        }
      ]
    }
  ]
}

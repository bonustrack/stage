{
  "type": "Row",
  "wrap": "wrap",
  "children": [
    {
      "$repeat": "items",
      "$item": {
        "type": "Box",
        "width": "50%",
        "padding": 6,
        "children": [
          {
            "type": "Pressable",
            "onClickAction": { "type": "{{openType}}", "payload": "{{item.payload}}" },
            "children": [
              {
                "type": "Col",
                "gap": 6,
                "children": [
                  {
                    "$if": "item.image",
                    "type": "Image",
                    "src": "{{item.image}}",
                    "fit": "cover",
                    "width": "100%",
                    "aspectRatio": 1,
                    "radius": "xl",
                    "background": "{{cardBg}}"
                  },
                  {
                    "$if": "item.noImage",
                    "type": "Box",
                    "width": "100%",
                    "aspectRatio": 1,
                    "radius": "xl",
                    "background": "{{cardBg}}",
                    "align": "center",
                    "justify": "center",
                    "children": [
                      { "type": "Icon", "name": "photo", "color": "secondary", "size": "2xl" }
                    ]
                  },
                  { "type": "Text", "value": "{{item.title}}", "weight": "semibold", "color": "link", "truncate": true },
                  { "$if": "item.collection", "type": "Caption", "value": "{{item.collection}}", "color": "secondary", "truncate": true }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}

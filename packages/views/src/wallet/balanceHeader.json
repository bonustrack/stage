{
  "type": "Col",
  "gap": 12,
  "children": [
    {
      "type": "Row",
      "align": "end",
      "children": [
        { "type": "Title", "value": "{{total}}", "weight": "semibold", "size": "{{heroSize}}" },
        {
          "$if": "totalDecimals",
          "type": "Title",
          "value": "{{totalDecimals}}",
          "weight": "semibold",
          "size": "{{heroSize}}",
          "color": "secondary"
        }
      ]
    },
    {
      "$if": "subtitle",
      "type": "Caption",
      "value": "{{subtitle}}",
      "color": "secondary"
    },
    {
      "$if": "hasActions",
      "type": "Row",
      "gap": 12,
      "justify": "start",
      "children": [
        {
          "$repeat": "actions",
          "$item": {
            "type": "Col",
            "gap": 6,
            "align": "center",
            "children": [
              {
                "type": "Button",
                "uniform": true,
                "pill": true,
                "size": "xl",
                "iconStart": "{{item.icon}}",
                "iconSize": "xl",
                "color": "{{item.bg}}",
                "background": "{{item.bg}}",
                "onClickAction": { "type": "{{item.pressType}}", "payload": "{{item.payload}}" }
              },
              { "type": "Caption", "value": "{{item.label}}", "weight": "semibold" }
            ]
          }
        }
      ]
    }
  ]
}

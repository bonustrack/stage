{
  "type": "Row",
  "gap": "{{gap}}",
  "justify": "start",
  "children": [
    {
      "$repeat": "actions",
      "$item": {
        "type": "Col",
        "gap": 6,
        "align": "center",
        "children": [
          {
            "type": "Button",
            "uniform": true,
            "pill": true,
            "size": "xl",
            "iconStart": "{{item.icon}}",
            "iconSize": "xl",
            "color": "{{item.bg}}",
            "background": "{{item.bg}}",
            "onClickAction": { "type": "{{item.pressType}}", "payload": "{{item.payload}}" }
          },
          { "type": "Caption", "value": "{{item.label}}", "weight": "semibold" }
        ]
      }
    }
  ]
}

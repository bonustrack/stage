{
  "type": "Form",
  "direction": "col",
  "gap": 8,
  "onSubmitAction": { "type": "{{submitAction}}", "payload": {} },
  "children": [
    { "type": "Caption", "value": "RECIPIENT", "color": "secondary", "size": "sm" },
    {
      "type": "Input",
      "name": "{{recipientName}}",
      "defaultValue": "{{recipientValue}}",
      "placeholder": "{{recipientPlaceholder}}"
    },
    { "type": "Caption", "value": "AMOUNT", "color": "secondary", "size": "sm" },
    {
      "type": "Input",
      "name": "{{amountName}}",
      "inputType": "number",
      "defaultValue": "{{amountValue}}",
      "placeholder": "{{amountPlaceholder}}"
    },
    {
      "$if": "hasToken",
      "type": "Caption",
      "value": "TOKEN",
      "color": "secondary",
      "size": "sm"
    },
    {
      "$if": "hasToken",
      "type": "Select",
      "name": "{{tokenName}}",
      "options": "{{tokenOptions}}",
      "defaultValue": "{{tokenValue}}"
    },
    {
      "$if": "hasReview",
      "type": "ListView",
      "children": [
        {
          "$repeat": "reviewRows",
          "$item": {
            "type": "ListViewItem",
            "align": "center",
            "gap": 12,
            "children": [
              {
                "type": "Col",
                "flex": 1,
                "children": [{ "type": "Text", "value": "{{item.label}}", "size": "md", "color": "secondary" }]
              },
              { "type": "Text", "value": "{{item.value}}", "size": "md", "truncate": true }
            ]
          }
        }
      ]
    },
    {
      "type": "Button",
      "label": "{{submitLabel}}",
      "submit": true,
      "block": true,
      "color": "primary",
      "disabled": "{{submitDisabled}}",
      "onClickAction": { "type": "{{submitAction}}", "payload": {} }
    }
  ]
}

{
  "type": "Col",
  "gap": 8,
  "children": [
    { "type": "Caption", "value": "{{labelUpper}}", "color": "secondary", "size": "sm" },
    {
      "type": "ListViewItem",
      "onClickAction": { "type": "{{copyAction}}", "payload": "{{copyPayload}}" },
      "align": "center",
      "gap": 12,
      "children": [
        {
          "type": "Col",
          "flex": 1,
          "children": [{ "type": "Text", "value": "{{addressDisplay}}", "size": "md", "truncate": true }]
        },
        { "type": "Icon", "name": "copy", "color": "secondary", "size": "sm" },
        {
          "$if": "hasShare",
          "type": "Icon",
          "name": "share",
          "color": "secondary",
          "size": "sm"
        }
      ]
    },
    {
      "$if": "hint",
      "type": "Caption",
      "value": "{{hint}}",
      "color": "secondary",
      "textAlign": "center"
    }
  ]
}

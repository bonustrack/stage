{
  "type": "ListView",
  "children": [
    {
      "$repeat": "rows",
      "$item": {
        "type": "ListViewItem",
        "align": "center",
        "gap": 12,
        "children": [
          {
            "type": "Col",
            "flex": 1,
            "children": [{ "type": "Text", "value": "{{item.label}}", "size": "md", "color": "secondary" }]
          },
          { "type": "Text", "value": "{{item.value}}", "size": "md", "truncate": true }
        ]
      }
    }
  ]
}

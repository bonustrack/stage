{
  "type": "Chart",
  "height": "{{height}}",
  "showYAxis": false,
  "showLegend": false,
  "xAxis": { "dataKey": "t", "hide": true },
  "series": [
    {
      "type": "{{seriesType}}",
      "dataKey": "price",
      "color": "{{color}}"
    }
  ],
  "data": [
    {
      "$repeat": "points",
      "$item": { "t": "{{item.t}}", "price": "{{item.price}}" }
    }
  ]
}

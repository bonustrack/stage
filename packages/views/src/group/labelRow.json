{
  "type": "Row",
  "gap": 8,
  "wrap": "wrap",
  "align": "center",
  "children": [
    {
      "$repeat": "labels",
      "$item": {
        "type": "Row",
        "align": "center",
        "gap": 6,
        "radius": "full",
        "background": "{{background}}",
        "padding": { "y": 6, "left": 12, "right": 8 },
        "children": [
          { "type": "Text", "value": "{{item.label}}", "size": "xs" },
          {
            "$if": "item.removable",
            "type": "Button",
            "iconStart": "x",
            "variant": "ghost",
            "size": "sm",
            "color": "secondary",
            "onClickAction": { "type": "{{removeType}}", "payload": { "label": "{{item.label}}" } }
          }
        ]
      }
    }
  ]
}

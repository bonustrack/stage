{
  "name": "@metro-labs/client",
  "version": "0.1.0",
  "private": true,
  "description": "Framework-agnostic shared logic for the Metro clients (web + mobile): Snapshot profiles, XMTP content humanisation, embed detection, Stamp resolution, and shared types. Pure TypeScript — no Vue / React / react-native.",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./profile/snapshot": "./src/profile/snapshot.ts",
    "./xmtp/humanize": "./src/xmtp/humanize.ts",
    "./xmtp/poll": "./src/xmtp/poll.ts",
    "./xmtp/sign": "./src/xmtp/sign.ts",
    "./xmtp/tx": "./src/xmtp/tx.ts",
    "./embed/detect": "./src/embed/detect.ts",
    "./stamp/resolve": "./src/stamp/resolve.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}

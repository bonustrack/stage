{
  "name": "@stage-labs/config",
  "version": "0.1.0-beta.0",
  "description": "Generic, repo-agnostic lint/TypeScript configuration: a base ESLint flat-config preset, a single-package composer, a parametric Vue preset, shared madge options, and the matching tsconfig bases. Consumers compose these; repo-specific topology (monorepo scoping, knip workspaces, app/kit rules) stays in the consuming repo.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bonustrack/stage.git",
    "directory": "packages/config"
  },
  "type": "module",
  "files": [
    "eslint",
    "madge",
    "tsconfig"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./eslint/base": "./eslint/base.js",
    "./eslint/vue": "./eslint/vue.js",
    "./eslint/single": "./eslint/single.js",
    "./madge": "./madge/index.js",
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/react-native.json": "./tsconfig/react-native.json",
    "./tsconfig/vue.json": "./tsconfig/vue.json"
  },
  "dependencies": {
    "eslint-plugin-jsdoc": "^63.0.6"
  },
  "peerDependencies": {
    "eslint": "*",
    "typescript-eslint": "*"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-vue": {
      "optional": true
    },
    "vue-eslint-parser": {
      "optional": true
    }
  }
}

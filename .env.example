# Configure at least one of Telegram or Discord. Copy to .env and fill in.

# ----- Telegram -----
# Bot token from @BotFather on Telegram. Required for the Telegram channel.
TELEGRAM_BOT_TOKEN=

# ----- Discord -----
# Bot token from https://discord.com/developers/applications.
# In the Bot tab → Privileged Gateway Intents, enable **Message Content Intent**
# — without it, messageCreate events arrive with empty content.
DISCORD_BOT_TOKEN=

# ----- GitHub mention bridge (optional; requires Discord) -----
# When the bot's GitHub user is @-mentioned in an issue/PR/comment, metro
# spawns a Discord thread for that issue and the agent answers there.
# All three must be set; see the README's "GitHub mentions" section.
GITHUB_WEBHOOK_SECRET=
GITHUB_BOT_USERNAME=
GITHUB_BRIDGE_DISCORD=

# Webhook listener port. Default 4321.
METRO_GITHUB_PORT=

# ----- Optional -----
# Log verbosity. One of: trace | debug | info | warn | error | fatal. Default: info.
# Logs go to stderr.
METRO_LOG_LEVEL=

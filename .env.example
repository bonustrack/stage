# Configure at least one of Telegram or Discord. Both can be enabled together.

# ----- Telegram -----
TELEGRAM_BOT_TOKEN=

# Numeric chat id of the bot owner (default reply target).
# Find it: send any message to your bot, then GET
# https://api.telegram.org/bot<TOKEN>/getUpdates and read result[0].message.chat.id.
TELEGRAM_CHAT_ID=

# ----- Discord -----
# Bot token from https://discord.com/developers/applications.
# In Bot → Privileged Gateway Intents, enable **Message Content Intent**,
# otherwise message bodies arrive empty.
DISCORD_BOT_TOKEN=

# Optional default Discord channel snowflake. If unset, the agent must pass
# `channelId` to every tool call.
DISCORD_CHANNEL_ID=

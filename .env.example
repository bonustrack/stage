# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Numeric chat id of the bot owner (default reply target).
# Find it: send any message to your bot, then GET
# https://api.telegram.org/bot<TOKEN>/getUpdates and read result[0].message.chat.id.
TELEGRAM_CHAT_ID=

# Optional. Required only to transcribe Telegram voice notes / audio.
OPENAI_API_KEY=

# Optional. Transcription model (default: gpt-4o-mini-transcribe).
OPENAI_TRANSCRIBE_MODEL=

diff --git a/index.js b/index.js
index fb09c48..407b163 100644
--- a/index.js
+++ b/index.js
@@ -12,12 +12,25 @@ var channels = {};
  * The MessageCodec class provides two static methods to serialize/deserialize
  * the data sent through the events channel.
 */
+// BigInt is not representable in JSON. RAILGUN amounts are BigInt, so we tag
+// them as strings on serialize and rehydrate them on deserialize (mirrors
+// Railway-Wallet's nodejs-mobile-react-native patch).
+const BIGINT_TAG = '$#BIGINT#$';
+function bigIntReplacer(_key, value) {
+  return typeof value === 'bigint' ? BIGINT_TAG + value.toString() : value;
+}
+function bigIntReviver(_key, value) {
+  return typeof value === 'string' && value.startsWith(BIGINT_TAG)
+    ? BigInt(value.slice(BIGINT_TAG.length))
+    : value;
+}
+
 class MessageCodec {
   // This is a 'private' constructor, should only be used by this class
   // static methods.
   constructor(_event, ..._payload) {
     this.event = _event;
-    this.payload = JSON.stringify(_payload);
+    this.payload = JSON.stringify(_payload, bigIntReplacer);
   };
 
   // Serialize the message payload and the message.
@@ -31,7 +44,7 @@ class MessageCodec {
   static deserialize(message) {
     var envelope = JSON.parse(message);
     if (typeof envelope.payload !== 'undefined') {
-      envelope.payload = JSON.parse(envelope.payload);
+      envelope.payload = JSON.parse(envelope.payload, bigIntReviver);
     }
     return envelope;
   };
